<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:id="rootPane"
            fx:controller="org.example.csvquery.MainController"
            prefWidth="1140" prefHeight="920"
            styleClass="root-pane"
            stylesheets="@csv-query.css">

    <!-- ═══════════════════════ TOPBAR ═══════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="topbar">

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 20 0 16; -fx-min-height: 48;">
                <Label text="CSV-QUERY" styleClass="logo"/>
            </HBox>

            <Region styleClass="topbar-separator"/>

            <Button fx:id="btnAbrirCSV"   text="📄  Abrir CSV"       onAction="#onAbrirCSV"       styleClass="btn-topbar"/>
            <Button fx:id="btnLimpiar"    text="✕  Limpiar Consola"  onAction="#onLimpiarConsola" styleClass="btn-topbar"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Theme toggle -->
            <Button fx:id="btnTema" text="☀ Tema Claro" onAction="#onToggleTema" styleClass="btn-theme"/>

            <Region style="-fx-min-width: 8;"/>

            <Button fx:id="btnEjecutar" text="⚡  Ejecutar Consulta" onAction="#onEjecutarConsulta" styleClass="btn-execute"/>

            <Region style="-fx-min-width: 10;"/>
        </HBox>
    </top>

    <!-- ═══════════════════════ CENTER ═══════════════════════ -->
    <center>
        <HBox spacing="0">

            <!-- ─── LEFT: Editor + Results ─── -->
            <VBox HBox.hgrow="ALWAYS" spacing="0">

                <!-- ── Editor Tab Bar ── -->
                <HBox alignment="CENTER_LEFT" styleClass="editor-tabbar">
                    <HBox alignment="CENTER" spacing="8" styleClass="editor-active-tab">
                        <Label text="&lt;/&gt;" styleClass="tab-icon"/>
                        <Label text="query_editor.sql"  styleClass="tab-filename"/>
                        <Label fx:id="lblEstado" text="● LISTO" styleClass="lbl-estado"/>
                    </HBox>
                </HBox>

                <!-- ── SQL Editor ── -->
                <HBox VBox.vgrow="ALWAYS" styleClass="editor-container">

                    <!-- Line numbers -->
                    <VBox fx:id="lineNumbers" alignment="TOP_RIGHT" styleClass="line-numbers">
                        <Label text="1" styleClass="line-number"/>
                        <Label text="2" styleClass="line-number"/>
                        <Label text="3" styleClass="line-number"/>
                    </VBox>

                    <TextArea fx:id="editorSQL" HBox.hgrow="ALWAYS" wrapText="false" styleClass="editor-textarea"/>
                </HBox>

                <!-- ── Status Bar ── -->
                <HBox alignment="CENTER_LEFT" spacing="16" styleClass="statusbar">
                    <Label text="ARCHIVO:"  styleClass="statusbar-label"/>
                    <Label fx:id="lblArchivo"  text="DATOS.CSV"     styleClass="statusbar-value"/>
                    <Label text="COLUMNAS:" styleClass="statusbar-label"/>
                    <Label fx:id="lblColumnas" text="8"             styleClass="statusbar-value"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblEncoding" text="UTF-8"         styleClass="statusbar-meta"/>
                    <Label fx:id="lblCursor"   text="LÍNEA 1, COL 1" styleClass="statusbar-meta"/>
                </HBox>

                <!-- ── Results Tabs ── -->
                <HBox alignment="CENTER_LEFT" styleClass="results-tabbar">
                    <Button fx:id="tabResultado" text="🟩  RESULTADO DE CONSULTA"    onAction="#onTabResultado" styleClass="btn-tab-active"/>
                    <Button fx:id="tabLexico"    text="🌿  ANÁLISIS SINTÁCTICO"           onAction="#onTabLexico"    styleClass="btn-tab"/>
                    <Button fx:id="tabTokens"    text="🔷  TOKENS"                   onAction="#onTabTokens"    styleClass="btn-tab"/>
                    <Button fx:id="tabConsola"   text="🖥  CONSOLA DE COMPILACIÓN"   onAction="#onTabConsola"   styleClass="btn-tab"/>
                </HBox>

                <!-- ══════════════════════════════════════════════════════
                     StackPane: apila tablaResultados y panelLexico.
                     Solo uno tiene visible="true" a la vez.
                     VBox.vgrow="ALWAYS" hace que ocupe todo el espacio
                     restante igual que antes lo hacía la tabla sola.
                ═══════════════════════════════════════════════════════ -->
                <StackPane VBox.vgrow="ALWAYS">

                    <!-- Tabla de resultados / tokens / consola -->
                    <TableView fx:id="tablaResultados"
                               styleClass="results-table"
                               visible="true">
                        <placeholder>
                            <Label text="Ejecuta una consulta para ver los resultados"
                                   styleClass="table-placeholder"/>
                        </placeholder>
                    </TableView>

                    <!-- Panel de análisis léxico por cláusula -->
                    <ScrollPane fx:id="panelLexico"
                                fitToWidth="true"
                                visible="false"
                                styleClass="panel-lexico-scroll">
                        <content>
                            <VBox fx:id="vboxLexico"
                                  spacing="10"
                                  style="-fx-padding: 14 14 14 14;"/>
                        </content>
                    </ScrollPane>

                </StackPane>

            </VBox>

            <!-- ─── RIGHT: Data Dictionary ─── -->
            <VBox fx:id="dictPanel" spacing="0" styleClass="dict-panel">

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="dict-header">
                    <Label text="📦" styleClass="dict-icon"/>
                    <VBox spacing="2">
                        <Label text="DICCIONARIO_DE_DATOS" styleClass="dict-title"/>
                        <Label text="v10.4-estable"        styleClass="dict-version"/>
                    </VBox>
                </HBox>

                <Label text="COLUMNAS DETECTADAS" styleClass="dict-section-title"/>

                <!-- Columna ID (activa) -->
                <HBox alignment="CENTER_LEFT" styleClass="dict-col-row-active">
                    <Label text="ID"    HBox.hgrow="ALWAYS" styleClass="dict-col-name-active"/>
                    <Label text="(int)"                     styleClass="dict-col-type-active"/>
                </HBox>

                <!-- Columna NOMBRE -->
                <HBox alignment="CENTER_LEFT" styleClass="dict-col-row">
                    <Label text="NOMBRE" HBox.hgrow="ALWAYS" styleClass="dict-col-name"/>
                    <Label text="(string)"                   styleClass="dict-col-type"/>
                </HBox>

                <!-- Columna EDAD -->
                <HBox alignment="CENTER_LEFT" styleClass="dict-col-row">
                    <Label text="EDAD" HBox.hgrow="ALWAYS" styleClass="dict-col-name"/>
                    <Label text="(int)"                    styleClass="dict-col-type"/>
                </HBox>

                <!-- Columna EMAIL -->
                <HBox alignment="CENTER_LEFT" styleClass="dict-col-row">
                    <Label text="EMAIL" HBox.hgrow="ALWAYS" styleClass="dict-col-name"/>
                    <Label text="(string)"                  styleClass="dict-col-type"/>
                </HBox>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Metadatos -->
                <Label text="METADATOS" styleClass="dict-section-title"
                       style="-fx-border-color: -color-border; -fx-border-width: 1 0 0 0;"/>

                <HBox styleClass="meta-cards-row" spacing="4">
                    <VBox HBox.hgrow="ALWAYS" spacing="4" styleClass="meta-card">
                        <Label text="FILAS"              styleClass="meta-card-label"/>
                        <Label fx:id="lblFilas" text="—" styleClass="meta-card-value"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="4" styleClass="meta-card">
                        <Label text="PESO"               styleClass="meta-card-label"/>
                        <Label fx:id="lblPeso"  text="—" styleClass="meta-card-value"/>
                    </VBox>
                </HBox>

            </VBox>

        </HBox>
    </center>

</BorderPane>
