<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:id="rootPane"
            fx:controller="org.example.csvquery.MainController"
            prefWidth="1140" prefHeight="920"
            styleClass="root-pane"
            stylesheets="@csv-query.css">

    <!-- ═══════════════════════ TOPBAR ═══════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="topbar">

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 20 0 16; -fx-min-height: 48;">
                <Label text="CSV-QUERY" styleClass="logo"/>
            </HBox>

            <Region styleClass="topbar-separator"/>

            <Button fx:id="btnAbrirCSV"   text="📄  Abrir CSV"       onAction="#onAbrirCSV"       styleClass="btn-topbar"/>
            <Button fx:id="btnLimpiar"    text="✕  Limpiar Consola"  onAction="#onLimpiarConsola" styleClass="btn-topbar"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Theme toggle -->
            <Button fx:id="btnTema" text="☀ Tema Claro" onAction="#onToggleTema" styleClass="btn-theme"/>

            <Region style="-fx-min-width: 8;"/>

            <Button fx:id="btnEjecutar" text="⚡  Ejecutar Consulta" onAction="#onEjecutarConsulta" styleClass="btn-execute"/>

            <Region style="-fx-min-width: 10;"/>
        </HBox>
    </top>

    <!-- ═══════════════════════ CENTER ═══════════════════════ -->
    <center>
        <HBox spacing="0">

            <!-- ─── LEFT: Editor + Results ─── -->
            <VBox HBox.hgrow="ALWAYS" spacing="0">

                <!-- ── Editor Tab Bar ── -->
                <HBox alignment="CENTER_LEFT" styleClass="editor-tabbar">
                    <HBox alignment="CENTER" spacing="8" styleClass="editor-active-tab">
                        <Label text="&lt;/&gt;" styleClass="tab-icon"/>
                        <Label text="query_editor.sql"  styleClass="tab-filename"/>
                        <Label fx:id="lblEstado" text="● LISTO" styleClass="lbl-estado"/>
                    </HBox>
                </HBox>

                <!-- ══════════════════════════════════════════════════════
                     SplitPane vertical: divide el espacio entre el editor
                     (arriba) y los resultados (abajo) de forma fija.
                     dividerPositions="0.35" = editor ocupa 35% del alto,
                     resultados el 65% restante. El usuario puede arrastrar.
                ═══════════════════════════════════════════════════════ -->
                <SplitPane orientation="VERTICAL"
                           dividerPositions="0.35"
                           VBox.vgrow="ALWAYS"
                           styleClass="main-split-pane">

                    <!-- ── Panel superior: editor + statusbar ── -->
                    <VBox minHeight="80" styleClass="editor-split-top">

                        <!-- SQL Editor (CodeArea se inyecta aquí desde el controller) -->
                        <StackPane fx:id="editorContainer" VBox.vgrow="ALWAYS"/>

                        <!-- Status Bar -->
                        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="statusbar">
                            <Label text="ARCHIVO:"  styleClass="statusbar-label"/>
                            <Label fx:id="lblArchivo"  text="DATOS.CSV"     styleClass="statusbar-value"/>
                            <Label text="COLUMNAS:" styleClass="statusbar-label"/>
                            <Label fx:id="lblColumnas" text="8"             styleClass="statusbar-value"/>
                            <Region HBox.hgrow="ALWAYS"/>
                            <Label fx:id="lblEncoding" text="UTF-8"         styleClass="statusbar-meta"/>
                            <Label fx:id="lblCursor"   text="LÍNEA 1, COL 1" styleClass="statusbar-meta"/>
                        </HBox>
                    </VBox>

                    <!-- ── Panel inferior: tabs + tabla/panel léxico ── -->
                    <VBox minHeight="80">

                        <!-- Results Tabs -->
                        <HBox alignment="CENTER_LEFT" styleClass="results-tabbar">
                            <Button fx:id="tabResultado"  text="🟩  RESULTADO DE CONSULTA"  onAction="#onTabResultado"  styleClass="btn-tab-active"/>
                            <Button fx:id="tabLexico"     text="🌿  ANÁLISIS SINTÁCTICO"     onAction="#onTabLexico"     styleClass="btn-tab"/>
                            <Button fx:id="tabTokens"     text="🔷  TOKENS"                 onAction="#onTabTokens"     styleClass="btn-tab"/>
                            <Button fx:id="tabConsola"    text="🖥  CONSOLA DE COMPILACIÓN" onAction="#onTabConsola"    styleClass="btn-tab"/>
                            <Button fx:id="tabCodigo"     text="🐍  CÓDIGO INTERMEDIO"      onAction="#onTabCodigo"     styleClass="btn-tab"/>
                        </HBox>

                        <!-- StackPane: apila tablaResultados y panelLexico -->
                        <StackPane VBox.vgrow="ALWAYS">

                            <TableView fx:id="tablaResultados"
                                       styleClass="results-table"
                                       visible="true">
                                <placeholder>
                                    <Label text="Ejecuta una consulta para ver los resultados"
                                           styleClass="table-placeholder"/>
                                </placeholder>
                            </TableView>

                            <ScrollPane fx:id="panelLexico"
                                        fitToWidth="true"
                                        visible="false"
                                        styleClass="panel-lexico-scroll">
                                <content>
                                    <VBox fx:id="vboxLexico"
                                          spacing="10"
                                          style="-fx-padding: 14 14 14 14;"/>
                                </content>
                            </ScrollPane>

                            <!-- Panel Consola de Compilación -->
                            <VBox fx:id="panelConsola" visible="false" styleClass="consola-root">
                                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="consola-header">
                                    <Label text="⬤" style="-fx-text-fill:#ff5f57; -fx-font-size:10px;"/>
                                    <Label text="⬤" style="-fx-text-fill:#febc2e; -fx-font-size:10px;"/>
                                    <Label text="⬤" style="-fx-text-fill:#28c840; -fx-font-size:10px;"/>
                                    <Region style="-fx-min-width:8;"/>
                                    <Label text="CONSOLA DE COMPILACIÓN" styleClass="consola-header-title"/>
                                </HBox>
                                <ScrollPane fx:id="consolaScroll" fitToWidth="true"
                                            VBox.vgrow="ALWAYS" styleClass="consola-scroll">
                                    <content>
                                        <VBox fx:id="vboxConsola" styleClass="consola-body" spacing="0"/>
                                    </content>
                                </ScrollPane>
                            </VBox>
                            <VBox fx:id="panelCodigo" visible="false" styleClass="panel-codigo-root">

                                <!-- Header del panel -->
                                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="panel-codigo-header">
                                    <Label text="🐍" style="-fx-font-size: 14px;"/>
                                    <Label text="CÓDIGO INTERMEDIO GENERADO" styleClass="panel-codigo-title"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label text="Python / Pandas" styleClass="panel-codigo-badge"/>
                                </HBox>

                                <!-- Área de código con scroll -->
                                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                                            styleClass="panel-codigo-scroll">
                                    <content>
                                        <TextArea fx:id="areaCodigo"
                                                  editable="false"
                                                  wrapText="false"
                                                  styleClass="area-codigo-python"
                                                  promptText="El código Python generado aparecerá aquí después de ejecutar una consulta."/>
                                    </content>
                                </ScrollPane>

                            </VBox>

                        </StackPane>
                    </VBox>

                </SplitPane>

            </VBox>

            <!-- ─── RIGHT: Data Dictionary ─── -->
            <VBox fx:id="dictPanel" spacing="0" styleClass="dict-panel">

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="dict-header">
<!--                    <Label text="📦" styleClass="dict-icon"/>-->
                    <ImageView fitHeight="50.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@logotec.png" />
                        </image>
                    </ImageView>
                    <VBox spacing="2">
                        <Label text="TECNOLÓGICO&#10;NACINAL DE MÉXICO&#10;EN CELAYA" styleClass="dict-title"/>
<!--                        <Label text="v10.4-estable"        styleClass="dict-version"/>-->
                    </VBox>
                </HBox>

                <Label text="LENGUAJES Y AUTÓMATAS ||" styleClass="dict-title"/>

                <!-- Columna ID (activa) -->
                <VBox alignment="CENTER" spacing="10">
                    <ImageView fitHeight="80.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@diego.jpg" />
                        </image>
                    </ImageView>
                    <Label text="DIEGO RAMIREZ VÁZQUEZ" HBox.hgrow="ALWAYS" styleClass="dict-col-name"/>
                </VBox>

                <VBox alignment="CENTER" spacing="10">
                    <ImageView fitHeight="80.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@ioni.jpg" />
                        </image>
                    </ImageView>
                    <Label text="JUAN JOSÉ HERNÁNDEZ PÉREZ" HBox.hgrow="ALWAYS" styleClass="dict-col-name"/>
                </VBox>

                <VBox alignment="CENTER" spacing="10">
                    <ImageView fitHeight="80.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@vladi.jpg" />
                        </image>
                    </ImageView>
                    <Label text="ALÍ VLADÍMIR CAÑADA GARCÍA" HBox.hgrow="ALWAYS" styleClass="dict-col-name"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <!-- Metadatos -->
                <Label text="METADATOS" styleClass="dict-section-title"
                       style="-fx-border-color: -color-border; -fx-border-width: 1 0 0 0;"/>

                <HBox styleClass="meta-cards-row" spacing="4">
                    <VBox HBox.hgrow="ALWAYS" spacing="4" styleClass="meta-card">
                        <Label text="FILAS"              styleClass="meta-card-label"/>
                        <Label fx:id="lblFilas" text="—" styleClass="meta-card-value"/>
                    </VBox>
                    <VBox HBox.hgrow="ALWAYS" spacing="4" styleClass="meta-card">
                        <Label text="PESO"               styleClass="meta-card-label"/>
                        <Label fx:id="lblPeso"  text="—" styleClass="meta-card-value"/>
                    </VBox>
                </HBox>

            </VBox>

        </HBox>
    </center>

</BorderPane>
