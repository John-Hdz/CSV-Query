<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane" prefHeight="920" prefWidth="1140" styleClass="root-pane" stylesheets="@csv-query.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.csvquery.MainController">

    <!-- ═══════════════════════ TOPBAR ═══════════════════════ -->
    <top>
        <HBox alignment="CENTER_LEFT" styleClass="topbar">

            <!-- Logo -->
            <HBox alignment="CENTER_LEFT" style="-fx-padding: 0 20 0 16; -fx-min-height: 48;">
                <Label styleClass="logo" text="CSV-QUERY" />
            </HBox>

            <Region styleClass="topbar-separator" />

            <Button fx:id="btnAbrirCSV" onAction="#onAbrirCSV" styleClass="btn-topbar" text="📄  Abrir CSV" />
            <Button fx:id="btnLimpiar" onAction="#onLimpiarConsola" styleClass="btn-topbar" text="✕  Limpiar Consola" />

            <Region HBox.hgrow="ALWAYS" />

            <!-- Theme toggle -->
            <Button fx:id="btnTema" onAction="#onToggleTema" styleClass="btn-theme" text="☀ Tema Claro" />

            <Region style="-fx-min-width: 8;" />

            <Button fx:id="btnEjecutar" onAction="#onEjecutarConsulta" styleClass="btn-execute" text="⚡  Ejecutar Consulta" />

            <Region style="-fx-min-width: 10;" />
        </HBox>
    </top>

    <!-- ═══════════════════════ CENTER ═══════════════════════ -->
    <center>
        <HBox spacing="0">

            <!-- ─── LEFT: Editor + Results ─── -->
            <VBox spacing="0" HBox.hgrow="ALWAYS">

                <!-- ── Editor Tab Bar ── -->
                <HBox alignment="CENTER_LEFT" styleClass="editor-tabbar">
                    <HBox alignment="CENTER" spacing="8" styleClass="editor-active-tab">
                        <Label styleClass="tab-icon" text="&lt;/&gt;" />
                        <Label styleClass="tab-filename" text="query_editor.sql" />
                        <Label fx:id="lblEstado" styleClass="lbl-estado" text="● LISTO" />
                    </HBox>
                </HBox>

                <!-- ══════════════════════════════════════════════════════
                     SplitPane vertical: divide el espacio entre el editor
                     (arriba) y los resultados (abajo) de forma fija.
                     dividerPositions="0.35" = editor ocupa 35% del alto,
                     resultados el 65% restante. El usuario puede arrastrar.
                ═══════════════════════════════════════════════════════ -->
                <SplitPane dividerPositions="0.35" orientation="VERTICAL" styleClass="main-split-pane" VBox.vgrow="ALWAYS">

                    <!-- ── Panel superior: editor + statusbar ── -->
                    <VBox minHeight="80" styleClass="editor-split-top">

                        <!-- SQL Editor (CodeArea se inyecta aquí desde el controller) -->
                        <StackPane fx:id="editorContainer" VBox.vgrow="ALWAYS" />

                        <!-- Status Bar -->
                        <HBox alignment="CENTER_LEFT" spacing="16" styleClass="statusbar">
                            <Label styleClass="statusbar-label" text="ARCHIVO:" />
                            <Label fx:id="lblArchivo" styleClass="statusbar-value" text="DATOS.CSV" />
                            <Label styleClass="statusbar-label" text="COLUMNAS:" />
                            <Label fx:id="lblColumnas" styleClass="statusbar-value" text="8" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="lblEncoding" styleClass="statusbar-meta" text="UTF-8" />
                            <Label fx:id="lblCursor" styleClass="statusbar-meta" text="LÍNEA 1, COL 1" />
                        </HBox>
                    </VBox>

                    <!-- ── Panel inferior: tabs + tabla/panel léxico ── -->
                    <VBox minHeight="80">

                        <!-- Results Tabs -->
                        <HBox alignment="CENTER_LEFT" styleClass="results-tabbar">
                            <Button fx:id="tabResultado" onAction="#onTabResultado" styleClass="btn-tab-active" text="🟩  RESULTADO DE CONSULTA" />
                            <Button fx:id="tabLexico" onAction="#onTabLexico" styleClass="btn-tab" text="🌿  ANÁLISIS SINTÁCTICO" />
                            <Button fx:id="tabTokens" onAction="#onTabTokens" styleClass="btn-tab" text="🔷  TOKENS" />
                            <Button fx:id="tabConsola" onAction="#onTabConsola" styleClass="btn-tab" text="🖥  CONSOLA DE COMPILACIÓN" />
                            <Button fx:id="tabCodigo" onAction="#onTabCodigo" styleClass="btn-tab" text="🐍  CÓDIGO INTERMEDIO" />
                        </HBox>

                        <!-- StackPane: apila tablaResultados y panelLexico -->
                        <StackPane VBox.vgrow="ALWAYS">

                            <TableView fx:id="tablaResultados" styleClass="results-table" visible="true">
                                <placeholder>
                                    <Label styleClass="table-placeholder" text="Ejecuta una consulta para ver los resultados" />
                                </placeholder>
                            </TableView>

                            <ScrollPane fx:id="panelLexico" fitToWidth="true" styleClass="panel-lexico-scroll" visible="false">
                                <content>
                                    <VBox fx:id="vboxLexico" spacing="10" style="-fx-padding: 14 14 14 14;" />
                                </content>
                            </ScrollPane>

                            <!-- Panel Consola de Compilación -->
                            <VBox fx:id="panelConsola" styleClass="consola-root" visible="false">
                                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="consola-header">
                                    <Label style="-fx-text-fill:#ff5f57; -fx-font-size:10px;" text="⬤" />
                                    <Label style="-fx-text-fill:#febc2e; -fx-font-size:10px;" text="⬤" />
                                    <Label style="-fx-text-fill:#28c840; -fx-font-size:10px;" text="⬤" />
                                    <Region style="-fx-min-width:8;" />
                                    <Label styleClass="consola-header-title" text="CONSOLA DE COMPILACIÓN" />
                                </HBox>
                                <ScrollPane fx:id="consolaScroll" fitToWidth="true" styleClass="consola-scroll" VBox.vgrow="ALWAYS">
                                    <content>
                                        <VBox fx:id="vboxConsola" spacing="0" styleClass="consola-body" />
                                    </content>
                                </ScrollPane>
                            </VBox>
                            <VBox fx:id="panelCodigo" styleClass="panel-codigo-root" visible="false">

                                <!-- Header del panel -->
                                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="panel-codigo-header">
                                    <Label style="-fx-font-size: 14px;" text="🐍" />
                                    <Label styleClass="panel-codigo-title" text="CÓDIGO INTERMEDIO GENERADO" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label styleClass="panel-codigo-badge" text="Python / Pandas" />
                                </HBox>

                                <!-- Área de código con scroll -->
                                <ScrollPane fitToWidth="true" styleClass="panel-codigo-scroll" VBox.vgrow="ALWAYS">
                                    <content>
                                        <TextArea fx:id="areaCodigo" editable="false" promptText="El código Python generado aparecerá aquí después de ejecutar una consulta." styleClass="area-codigo-python" wrapText="false" />
                                    </content>
                                </ScrollPane>

                            </VBox>

                        </StackPane>
                    </VBox>

                </SplitPane>

            </VBox>

            <!-- ─── RIGHT: Data Dictionary ─── -->
            <VBox fx:id="dictPanel" spacing="0" styleClass="dict-panel">

                <!-- Header -->
                <HBox alignment="CENTER_LEFT" spacing="10" styleClass="dict-header">
<!--                    <Label text="📦" styleClass="dict-icon"/>-->
                    <ImageView fitHeight="50.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@logotec.png" />
                        </image>
                    </ImageView>
                    <VBox spacing="2">
                        <Label styleClass="dict-title" text="TECNOLÓGICO&#10;NACINAL DE MÉXICO&#10;EN CELAYA" />
<!--                        <Label text="v10.4-estable"        styleClass="dict-version"/>-->
                    </VBox>
                </HBox>

                <Label styleClass="dict-title" text="LENGUAJES Y AUTÓMATAS ||" />

                <!-- Columna ID (activa) -->
                <VBox alignment="CENTER" spacing="10">
                    <ImageView fitHeight="80.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@diego.jpg" />
                        </image>
                    </ImageView>
                    <Label styleClass="dict-col-name" text="DIEGO RAMIREZ VÁZQUEZ" HBox.hgrow="ALWAYS" />
                </VBox>

                <VBox alignment="CENTER" spacing="10">
                    <ImageView fitHeight="80.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@ioni.jpg" />
                        </image>
                    </ImageView>
                    <Label styleClass="dict-col-name" text="JUAN JOSÉ HERNÁNDEZ PÉREZ" HBox.hgrow="ALWAYS" />
                </VBox>

                <VBox alignment="CENTER" spacing="10">
                    <ImageView fitHeight="80.0" pickOnBounds="true" preserveRatio="true">
                        <image>
                            <Image url="@vladi.jpg" />
                        </image>
                    </ImageView>
                    <Label styleClass="dict-col-name" text="ALÍ VLADÍMIR CAÑADA GARCÍA" HBox.hgrow="ALWAYS" />
                </VBox>
            <Label layoutX="11.0" layoutY="771.0" style="-fx-border-color: -color-border; -fx-border-width: 1 0 0 0;" styleClass="dict-section-title" />
            <HBox alignment="TOP_CENTER" prefHeight="100.0" prefWidth="200.0">
               <children>
                  <Button mnemonicParsing="false" text="Visualizar documentacion." onAction="#abrirDocumentacion"/>
               </children>
            </HBox>

                <Region VBox.vgrow="ALWAYS" />

                <!-- Metadatos -->
                <Label style="-fx-border-color: -color-border; -fx-border-width: 1 0 0 0;" styleClass="dict-section-title" text="METADATOS" />

                <HBox spacing="4" styleClass="meta-cards-row">
                    <VBox spacing="4" styleClass="meta-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="meta-card-label" text="FILAS" />
                        <Label fx:id="lblFilas" styleClass="meta-card-value" text="—" />
                    </VBox>
                    <VBox spacing="4" styleClass="meta-card" HBox.hgrow="ALWAYS">
                        <Label styleClass="meta-card-label" text="PESO" />
                        <Label fx:id="lblPeso" styleClass="meta-card-value" text="—" />
                    </VBox>
                </HBox>

            </VBox>

        </HBox>
    </center>

</BorderPane>
